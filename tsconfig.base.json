{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@accord/core": ["packages/core/src/index.ts"],
      "@accord/core/*": ["packages/core/src/*"],
      "@accord/execution": ["packages/execution/src/index.ts"],
      "@accord/execution/*": ["packages/execution/src/*"]
    }
  }
}
