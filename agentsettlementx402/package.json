{
  "name": "cross-agent-reputation-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "api:start": "tsx -e \"import { runApiServerFromEnvironment } from './src/api/cli.ts'; void runApiServerFromEnvironment();\"",
    "build": "tsc -p tsconfig.build.json",
    "coverage": "vitest run --coverage",
    "dev": "pnpm api:start",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "scheduler:ensure": "tsx -e \"import { ensureScheduleFromEnvironment } from './src/scheduler/cli.ts'; void ensureScheduleFromEnvironment();\"",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "worker:run": "tsx -e \"import { runWorkerFromEnvironment } from './src/worker/cli.ts'; void runWorkerFromEnvironment();\"",
    "worker:serve": "tsx -e \"import { startWorkerReceiverFromEnvironment } from './src/worker/cli.ts'; void startWorkerReceiverFromEnvironment();\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@upstash/qstash": "^2.8.2",
    "@upstash/redis": "^1.35.6",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.6",
    "tsx": "^4.20.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
